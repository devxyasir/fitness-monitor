# Production override for docker-compose.yml's LiveKit service.
#
# Copy this to `.env` in the same directory (already gitignored — never
# commit real credentials) and fill in real values. Without this file,
# `docker compose up` falls back to the local-dev quickstart: --dev mode
# and the well-known default devkey:secret keys, which must never run in
# production (see the comment on the livekit service in docker-compose.yml).
#
# Generate a real key/secret pair, e.g.:
#   LIVEKIT_KEY="lk$(openssl rand -hex 8)"
#   LIVEKIT_SECRET="$(openssl rand -hex 24)"
#
# The same key:secret pair must also be set as LIVEKIT_API_KEY /
# LIVEKIT_API_SECRET in apps/api's own .env — the API mints room-join JWTs
# signed with these, which LiveKit validates against what it was started
# with. If they don't match, every join request fails.

LIVEKIT_COMMAND=--keys REPLACE_WITH_KEY:REPLACE_WITH_SECRET
LIVEKIT_KEYS=REPLACE_WITH_KEY:REPLACE_WITH_SECRET
