# apps/web .env.example
#
# Copy to .env.local and fill in real values — never commit .env.local

# API base URL (used by lib/api-client.ts)
NEXT_PUBLIC_API_URL=http://localhost:3001

# LiveKit SFU URL (used by lib/livekit-client.ts)
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# WebSocket Gateway URL (same as API for Phase 0; may split later)
NEXT_PUBLIC_WS_URL=http://localhost:3001
