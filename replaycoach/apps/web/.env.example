# apps/web .env.example
#
# Copy to .env.local and fill in real values — never commit .env.local

# API base URL (used by lib/api-client.ts)
NEXT_PUBLIC_API_URL=http://localhost:3001

# NOTE: the LiveKit SFU URL is NOT configured here. lib/livekit-client.ts
# gets it from the join API response (server-side LIVEKIT_URL in apps/api's
# .env) — set that instead. A frontend var here would be dead/misleading.

# WebSocket Gateway URL (same as API for Phase 0; may split later)
NEXT_PUBLIC_WS_URL=http://localhost:3001
DOTENV_CONFIG_QUIET=true