# apps/api .env.example
#
# Copy to .env and fill in real values — never commit .env

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL — not used yet, placeholder for Phase 1)
# DATABASE_URL=postgresql://user:password@localhost:5432/replaycoach

# Redis (not used yet, placeholder for Phase 1)
# REDIS_URL=redis://localhost:6379

# JWT (not used yet, placeholder for Phase 1)
# JWT_SECRET=change-me
# JWT_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# Refresh-cookie strategy — defaults are correct for local dev (web + API same-site).
# Only set these in production if web and API are served from different registrable
# domains (SameSite=Strict would silently block the refresh cookie otherwise).
# AUTH_COOKIE_SAMESITE=strict   # 'strict' | 'lax' | 'none' ('none' requires HTTPS)
# AUTH_COOKIE_DOMAIN=           # e.g. .replaycoach.example.com

# AWS S3 (not used yet, placeholder for Phase 2)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_RECORDINGS=
# AWS_S3_BUCKET_CLIPS=

# LiveKit (not used yet, placeholder for Phase 1)
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
