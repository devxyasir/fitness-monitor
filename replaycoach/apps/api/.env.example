# apps/api .env.example
#
# Copy to .env and fill in real values — never commit .env

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL — not used yet, placeholder for Phase 1)
# DATABASE_URL=postgresql://user:password@localhost:5432/replaycoach

# Redis (not used yet, placeholder for Phase 1)
# REDIS_URL=redis://localhost:6379

# JWT (not used yet, placeholder for Phase 1)
# JWT_SECRET=change-me
# JWT_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# Refresh-cookie strategy — defaults are correct for local dev (web + API same-site).
# Only set these in production if web and API are served from different registrable
# domains (SameSite=Strict would silently block the refresh cookie otherwise).
# AUTH_COOKIE_SAMESITE=strict   # 'strict' | 'lax' | 'none' ('none' requires HTTPS)
# AUTH_COOKIE_DOMAIN=           # e.g. .replaycoach.example.com

# Pose-service callback + media-streaming HMAC signing secret.
# MUST be different from JWT_SECRET. Used to sign local-disk media URLs
# and to verify pose-service completion callbacks. Min 32 chars.
# CALLBACK_TOKEN_SECRET=change-me-to-a-random-32-char-string

# AWS S3 (not used yet, placeholder for Phase 2)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_RECORDINGS=
# AWS_S3_BUCKET_CLIPS=

# Reference-video analysis storage. Leave unset for local dev — videos and
# keypoints JSON are stored under apps/api/uploads/ and served via a signed
# local route. Set this to switch to real S3 (credentials come from the
# standard AWS provider chain — env vars, shared config, or an IAM role).
# S3_REFERENCE_VIDEOS_BUCKET=replaycoach-reference-videos

# The API's own publicly-reachable base URL. Only needed in production —
# local dev defaults to http://localhost:$PORT, which is correct as long as
# the API and pose-service run on the same machine. Required once they don't
# (the pose-service calls this URL back when reference-video processing
# completes, and it's embedded in playback URLs handed to the browser).
# API_PUBLIC_URL=https://api.replaycoach.example.com

# LiveKit (not used yet, placeholder for Phase 1)
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
