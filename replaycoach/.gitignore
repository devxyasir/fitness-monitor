# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Local dev-mode media storage (reference videos stored on disk when no
# S3 credentials are configured — see ReferenceStorageService)
apps/api/uploads/

# Turborepo cache
.turbo/

# Environment files — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
# Exception: .env.example files are committed (they contain no secrets)
!**/.env.example

# AWS / cloud credentials
.aws/
*.pem
*.key
credentials

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/.terraform.lock.hcl

# Docker
.dockerignore

# Python virtual environments & cache
venv/
.venv/
env/
.env/
__pycache__/
*.pyc
*.pyo
*.pyd

# Pose-service ONNX checkpoints — too large for git; auto-downloaded on
# first run by model_downloader.py instead (see inference.py load()).
apps/pose-service/models/*.onnx

